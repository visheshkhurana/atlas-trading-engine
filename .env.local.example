# ═══════════════════════════════════════════════════════════════
# ATLAS Trading Engine - Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Supabase (Frontend - NEXT_PUBLIC prefix required) ────────
NEXT_PUBLIC_SUPABASE_URL=https://xyqeawbuiqqcbhsnyojn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Supabase (Backend - used by Python engine) ───────────────
SUPABASE_URL=https://xyqeawbuiqqcbhsnyojn.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── OKX Exchange (Primary) ───────────────────────────────────
# NOTE: Variable names match user's Vercel config
OKX_Keys=your_okx_api_key_here
Okx_Secret_keys=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ── Kraken Exchange (Secondary - optional) ───────────────────
Kraken_API=your_kraken_api_key_here
Kraken_Secret_Key=your_kraken_secret_key_here

# ── Engine Configuration ─────────────────────────────────────
PAPER_MODE=true
TRADING_INTERVAL=60
MAX_TRADES_PER_DAY=20
MAX_RISK_PER_TRADE=0.02
MAX_PORTFOLIO_EXPOSURE=0.20
MAX_LEVERAGE=3
MAX_DRAWDOWN=0.10
DAILY_LOSS_LIMIT=0.05
VOLATILITY_PAUSE_THRESHOLD=0.06
